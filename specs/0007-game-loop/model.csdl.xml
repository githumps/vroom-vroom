<?xml version="1.0" encoding="utf-8"?>
<!-- Spec 0007 GameLoop — CSDL companion (literal filename model.csdl.xml). -->
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>

    <Schema Namespace="Temper.Vocab" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <Term Name="StateMachine.States" Type="Collection(Edm.String)" AppliesTo="EntityType"/>
      <Term Name="StateMachine.InitialState" Type="Edm.String" AppliesTo="EntityType"/>
      <Term Name="StateMachine.ValidFromStates" Type="Collection(Edm.String)" AppliesTo="Action"/>
      <Term Name="StateMachine.TargetState" Type="Edm.String" AppliesTo="Action"/>
      <Term Name="Agent.Hint" Type="Edm.String" AppliesTo="Action EntityType"/>
      <Term Name="ShardKey" Type="Edm.String" AppliesTo="EntityType"/>
      <Term Name="AuthZ.CedarPolicy" Type="Edm.String" AppliesTo="EntityType Action"/>
    </Schema>

    <Schema Namespace="Vroom.GameLoop" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <EnumType Name="GameLoopStatus">
        <Member Name="Driving" Value="0"/>
        <Member Name="Arrest" Value="1"/>
        <Member Name="Courtroom" Value="2"/>
        <Member Name="Prison" Value="3"/>
      </EnumType>

      <EntityType Name="GameLoop">
        <Key><PropertyRef Name="GameLoopId"/></Key>
        <Property Name="GameLoopId" Type="Edm.String" Nullable="false"/>
        <Property Name="UserId" Type="Edm.String" Nullable="false"/>
        <Property Name="Status" Type="Vroom.GameLoop.GameLoopStatus" Nullable="false"/>

        <Annotation Term="Temper.Vocab.StateMachine.States">
          <Collection>
            <String>Driving</String>
            <String>Arrest</String>
            <String>Courtroom</String>
            <String>Prison</String>
          </Collection>
        </Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.InitialState" String="Driving"/>
        <Annotation Term="Temper.Vocab.ShardKey" String="UserId"/>
        <Annotation Term="Temper.Vocab.AuthZ.CedarPolicy" String="policies/game-loop.cedar"/>
      </EntityType>

      <Action Name="GetCaught" IsBound="true">
        <Parameter Name="bindingParameter" Type="Vroom.GameLoop.GameLoop"/>
        <Parameter Name="incident_id" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Vroom.GameLoop.GameLoop"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>Driving</String></Collection></Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Arrest"/>
      </Action>

      <Action Name="ProceedToCourt" IsBound="true">
        <Parameter Name="bindingParameter" Type="Vroom.GameLoop.GameLoop"/>
        <Parameter Name="case_id" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Vroom.GameLoop.GameLoop"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>Arrest</String></Collection></Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Courtroom"/>
      </Action>

      <Action Name="DeliverVerdict" IsBound="true">
        <Parameter Name="bindingParameter" Type="Vroom.GameLoop.GameLoop"/>
        <Parameter Name="sentence_id" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Vroom.GameLoop.GameLoop"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>Courtroom</String></Collection></Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Prison"/>
      </Action>

      <Action Name="ReleaseToStreets" IsBound="true">
        <Parameter Name="bindingParameter" Type="Vroom.GameLoop.GameLoop"/>
        <Parameter Name="release_id" Type="Edm.String" Nullable="false"/>
        <ReturnType Type="Vroom.GameLoop.GameLoop"/>
        <Annotation Term="Temper.Vocab.StateMachine.ValidFromStates"><Collection><String>Prison</String></Collection></Annotation>
        <Annotation Term="Temper.Vocab.StateMachine.TargetState" String="Driving"/>
      </Action>

      <EntityContainer Name="GameLoopService">
        <EntitySet Name="GameLoops" EntityType="Vroom.GameLoop.GameLoop"/>
      </EntityContainer>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
